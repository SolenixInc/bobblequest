{
  "extends": "./packages/config/tsconfig/base.json",
  "compilerOptions": {
    "checkJs": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@t/*": ["packages/*/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next", ".expo"]
}
