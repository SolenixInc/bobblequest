{
  "name": "@t/analytics-browser",
  "description": "Browser-side PostHog client used by apps/web and apps/website.",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write .",
    "format:check": "biome ci .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@t/analytics-types": "workspace:*",
    "@t/config": "workspace:*",
    "@t/dependency-injection": "workspace:*",
    "posthog-js": "^1.372.1"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "awilix": "^12",
    "@clerk/nextjs": "^6",
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "@clerk/nextjs": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^25.0.0",
    "next": "^15.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
