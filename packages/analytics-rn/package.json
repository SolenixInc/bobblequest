{
  "name": "@t/analytics-rn",
  "description": "React Native PostHog client used by apps/mobile.",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@t/analytics-types": "workspace:*",
    "@t/config": "workspace:*",
    "@t/dependency-injection": "workspace:*",
    "@t/logging-types": "workspace:*",
    "posthog-react-native": "^4.43.5"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-native": ">=0.73",
    "awilix": "^12",
    "@clerk/clerk-expo": "^2",
    "expo-file-system": ">=17",
    "expo-application": ">=5",
    "expo-device": ">=6",
    "expo-localization": ">=15",
    "@react-native-async-storage/async-storage": ">=1"
  },
  "peerDependenciesMeta": {
    "@clerk/clerk-expo": {
      "optional": true
    },
    "expo-file-system": {
      "optional": true
    },
    "expo-application": {
      "optional": true
    },
    "expo-device": {
      "optional": true
    },
    "expo-localization": {
      "optional": true
    },
    "@react-native-async-storage/async-storage": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
