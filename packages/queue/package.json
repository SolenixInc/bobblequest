{
  "name": "@t/queue",
  "description": "Bull job queue, Redis-backed, used by the API for background work.",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "format": "biome check --write ."
  },
  "dependencies": {
    "@t/config": "workspace:*",
    "@t/dependency-injection": "workspace:*",
    "@t/logging": "workspace:*",
    "bullmq": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
