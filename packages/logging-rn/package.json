{
  "name": "@t/logging-rn",
  "description": "React Native logging adapter used by apps/mobile.",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@t/analytics-types": "workspace:*",
    "@t/logging-types": "workspace:*",
    "@t/dependency-injection": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@t/analytics-types": "workspace:*",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
