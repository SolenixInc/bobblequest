{
  "name": "@t/db",
  "description": "Drizzle ORM, Postgres connection, and migrations for the API.",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schemas": {
      "types": "./src/entities/schemas/index.ts",
      "import": "./src/entities/schemas/index.ts"
    }
  },
  "scripts": {
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:test:up": "docker compose -f ../../docker-compose.db.yml up -d --wait",
    "db:test:down": "docker compose -f ../../docker-compose.db.yml down -v",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@t/config": "workspace:*",
    "@t/dependency-injection": "workspace:*",
    "@t/logging": "workspace:*",
    "drizzle-orm": "^0.45.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "awilix": "^12.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
