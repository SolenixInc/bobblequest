# =============================================================================
# Template Repo — Environment Variable Reference
# Copy to .env (local dev) or supply via your hosting platform.
# Values marked "REQUIRED" will cause a hard boot failure if absent.
# =============================================================================

# --- Database (Drizzle / pgvector) -------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/template"   # REQUIRED — full Postgres URL

# --- System ------------------------------------------------------------------
PORT=3000                                                     # optional; default 8000 in schema
ENVIRONMENT=development                                       # REQUIRED — development|local|testing|production
CORS_ORIGINS=http://localhost:3001,http://localhost:8081      # optional; comma-separated origins

# --- API internal secrets (SystemConfigSchema) --------------------------------
AI_SERVICE_URL=http://localhost:9999                          # REQUIRED — internal AI service endpoint
METRICS_AUTH_TOKEN=replace-me                                 # REQUIRED — bearer token for /metrics
SYSTEM_API_KEY=replace-me                                     # REQUIRED — service-to-service auth key
CRON_SECRET=replace-me                                        # REQUIRED — token for cron HTTP triggers

# --- Clerk Auth (AuthConfigSchema — all optional, but required for real auth) -
CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxx"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""                          # web / Next.js client — optional; empty → auth UI disabled (app still boots)
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxx"                       # server-only — never ship to client
CLERK_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"                     # svix signing secret for /webhooks/clerk

# --- tRPC / API URLs ---------------------------------------------------------
# api is hosted on port 3000 in stack:full; web on 3001; website on 3002
NEXT_PUBLIC_TRPC_URL="http://localhost:3000/trpc"             # Next.js web app
EXPO_PUBLIC_API_URL="http://localhost:3000"                   # Expo mobile app
VITE_API_URL="http://localhost:3000"                          # Electron desktop app

# --- Stripe (StripeConfigSchema — REQUIRED) -----------------------------------
STRIPE_KEY="sk_test_xxxxxxxxxxxx"                             # REQUIRED — Stripe secret key
STRIPE_REDIRECT_DOMAIN="http://localhost:3001"                # REQUIRED — base URL for checkout redirects
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"                    # REQUIRED — Stripe webhook signing secret

# --- RevenueCat (RevenueCatConfigSchema — REQUIRED) ---------------------------
CORE_REVENUE_CAT_API_KEY="replace-me"                         # REQUIRED — RevenueCat secret API key
CORE_REVENUE_CAT_PROJECT_ID="replace-me"                      # REQUIRED — RevenueCat project ID
CORE_REVENUE_CAT_NUTRAFORGE_ENTITLEMENT_ID="replace-me"       # REQUIRED — entitlement identifier
REVENUECAT_WEBHOOK_AUTH_HEADER="replace-me"                   # REQUIRED — webhook Authorization header value
EXPO_PUBLIC_REVENUECAT_APPLE_KEY="appl_xxxxxxxxxxxx"          # optional — iOS RevenueCat key
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY="goog_xxxxxxxxxxxx"         # optional — Android RevenueCat key

# --- Apple / App Store (AppleConfigSchema + AppStoreConfigSchema — REQUIRED) --
APPLE_PRODUCTION_URL="https://buy.itunes.apple.com/verifyReceipt"   # REQUIRED
APPLE_SANDBOX_URL="https://sandbox.itunes.apple.com/verifyReceipt"  # REQUIRED
APPLE_APP_SHARED_SECRET="replace-me"                                # REQUIRED — receipt validation shared secret
APP_STORE_BUNDLE_ID="com.yourcompany.yourapp"                        # REQUIRED
APP_STORE_ENVIRONMENT="Sandbox"                                      # REQUIRED — Sandbox|Production

# --- Android (AndroidConfigSchema — REQUIRED) ---------------------------------
ANDROID_PUBLISHER_URL="https://androidpublisher.googleapis.com/androidpublisher/v3"  # REQUIRED

# --- Analytics / PostHog (PostHogConfigSchema + AnalyticsConfigSchema — REQUIRED) ---
POSTHOG_API_KEY="phc_xxxxxxxxxxxx"                            # REQUIRED — public project API key
POSTHOG_HOST="https://us.i.posthog.com"                      # optional — region endpoint
POSTHOG_PERSONAL_API_KEY="phx_xxxxxxxxxxxx"                  # optional — server-side flag evaluation
POSTHOG_ENABLED=true                                          # optional — set false in CI/local to suppress events

# --- Redis (RedisConfigSchema — optional fields, needs one of URL or HOST) ----
REDIS_URL="redis://:redispassword@localhost:6380/0"           # optional when REDIS_HOST set
REDIS_PASSWORD="redispassword"                                # optional

# --- Mail (local dev — Mailpit) -----------------------------------------------
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=noreply@example.com

# --- Object Storage (local dev — MinIO) ---------------------------------------
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=template-uploads
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
