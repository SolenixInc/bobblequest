# Runtime environment (development | local | testing | production)
# Next.js sets NODE_ENV automatically; set ENVIRONMENT to align @t/config.
ENVIRONMENT=development

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# tRPC
NEXT_PUBLIC_TRPC_URL=http://localhost:3000/trpc

# PostHog (browser observability — apps/web client side)
# Required — schema hard-fails at boot if missing or empty.
# Set to a real phc_* key from your PostHog project.
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxx"
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# RevenueCat (browser billing — set to empty for NoOp tracker in local/test environments)
NEXT_PUBLIC_REVENUECAT_PUBLIC_API_KEY=
NEXT_PUBLIC_ENVIRONMENT=development
