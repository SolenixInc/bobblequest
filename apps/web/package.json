{
  "name": "@t/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "size": "size-limit"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.14",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@t/analytics": "workspace:*",
    "@t/analytics-browser": "workspace:*",
    "@t/billing-browser": "workspace:*",
    "@t/api": "workspace:*",
    "@t/config": "workspace:*",
    "@t/dependency-injection": "workspace:*",
    "@t/errors": "workspace:*",
    "@t/logging": "workspace:*",
    "@t/logging-browser": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.11.0",
    "clsx": "^2.1.1",
    "next": "^15.5.20",
    "posthog-js": "^1.372.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.22",
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  },
  "size-limit": [
    {
      "name": "Next.js client bundle",
      "path": ".next/static/**/*.js",
      "limit": "1800 kB"
    }
  ]
