{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "root": false,
  "extends": ["../../packages/config/biome.json"],
  "files": {
    "includes": ["!.next", "!node_modules", "!playwright-report", "!test-results", "!coverage"]
  },
  "css": {
    "parser": {
      "cssModules": false,
      "allowWrongLineComments": false,
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    }
  }
}
