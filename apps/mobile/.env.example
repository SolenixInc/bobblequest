# tRPC API endpoint
EXPO_PUBLIC_API_URL=http://localhost:3001/trpc

# Clerk Auth
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxx"

# RevenueCat (in-app purchases)
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=

# PostHog — required by MobileConfigValuesSchema. Schema hard-fails at boot if missing or empty.
# Set to a real phc_* key from your PostHog project.
EXPO_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxx"
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
