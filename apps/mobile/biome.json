{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "root": false,
  "extends": ["../../packages/config/biome.json"],
  "files": {
    "includes": ["!android", "!expo-env.d.ts", "!node_modules"]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.css"],
      "linter": {
        "rules": {
          "suspicious": {
            "noUnknownAtRules": "off"
          }
        }
      }
    }
  ]
}
