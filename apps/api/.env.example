# =============================================================================
# apps/api environment template
# =============================================================================
# Mirrors the env vars stubbed in apps/api/src/__tests__/setup.ts. Every var
# below is required for ConfigRepositoryImpl validation to pass at boot
# (ENVIRONMENT=testing skips DB binding but still validates the rest).
# Consuming projects supply their own values per environment.
# -----------------------------------------------------------------------------

# Runtime
PORT=3000
ENVIRONMENT="development"                         # development | local | testing | production

# Database (Drizzle on Railway Postgres)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Clerk auth
CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxx"      # optional in apps/api; required by client apps
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxx"           # server-side; used by @clerk/backend for JWKS + Backend API
CLERK_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"         # svix signing secret; verifies POST /api/webhooks/clerk

# Analytics — PostHog (server-side)
# Required — schema hard-fails at boot if missing or empty.
POSTHOG_API_KEY="phc_xxxxxxxxxxxx"

# System / observability
AI_SERVICE_URL="http://localhost:8000"
METRICS_AUTH_TOKEN="replace-me"
SYSTEM_API_KEY="replace-me"

# Cron — Bearer token verified by POST /api/cron/* endpoints.
# Required (z.string()) on SystemConfigSchema.cronSecret.
# Generate with: openssl rand -hex 32
CRON_SECRET="replace-me"

# Stripe (configured behind RevenueCat as the web payment rail)
STRIPE_KEY="sk_test_xxxxxxxxxxxx"
STRIPE_REDIRECT_DOMAIN="http://localhost:3001"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"

# Apple in-app purchase verification
APPLE_PRODUCTION_URL="https://buy.itunes.apple.com"
APPLE_SANDBOX_URL="https://sandbox.itunes.apple.com"
APPLE_APP_SHARED_SECRET="replace-me"

# App Store
APP_STORE_BUNDLE_ID="com.example.app"
APP_STORE_ENVIRONMENT="Sandbox"                   # Sandbox | Production

# Android publisher
ANDROID_PUBLISHER_URL="https://androidpublisher.googleapis.com"

# RevenueCat — primary billing layer across every app
CORE_REVENUE_CAT_API_KEY="replace-me"
CORE_REVENUE_CAT_PROJECT_ID="replace-me"
CORE_REVENUE_CAT_NUTRAFORGE_ENTITLEMENT_ID="replace-me"

# RevenueCat webhook — shared-secret value sent in the Authorization header
# of POST /api/webhooks/revenuecat. Configured in the RevenueCat dashboard:
# Project → Integrations → Webhooks → Authorization header.
# Required (z.string().min(1)) on RevenueCatConfigSchema.webhookAuthHeader.
REVENUECAT_WEBHOOK_AUTH_HEADER="replace-me"
