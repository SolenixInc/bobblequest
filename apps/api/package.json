{
  "name": "@t/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/routers/index.ts"
    }
  },
  "scripts": {
    "dev": "bun run --hot --cwd ../.. --env-file apps/api/.env apps/api/src/index.ts",
    "worker": "bun run src/worker.ts",
    "worker:dev": "bun run --watch src/worker.ts",
    "cron": "bun run src/cron.ts",
    "build": "bun build src/index.ts --outdir dist --target=node",
    "start": "bun dist/index.js",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "size": "size-limit"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.0",
    "@hono/trpc-server": "^0.4.0",
    "@t/analytics": "workspace:*",
    "@t/auth": "workspace:*",
    "@t/billing": "workspace:*",
    "@t/errors": "workspace:*",
    "@t/cache": "workspace:*",
    "@t/config": "workspace:*",
    "@t/db": "workspace:*",
    "@t/dependency-injection": "workspace:*",
    "@t/logging": "workspace:*",
    "@t/queue": "workspace:*",
    "@trpc/server": "^11.0.0",
    "hono": "^4.12.16",
    "svix": "^1.92.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  },
  "size-limit": [
    {
      "name": "API server bundle",
      "path": "dist/index.js",
      "limit": "4600 kB"
    }
  ]
}
