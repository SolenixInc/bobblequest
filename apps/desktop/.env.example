# Clerk Auth (renderer — publishable key only; no server-side secret needed in the desktop renderer)
VITE_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxx"

# API URL (renderer — defaults to http://localhost:3001 in dev builds; required in production)
VITE_API_URL="http://localhost:3001"

# RevenueCat Web SDK (renderer — publishable (public) key; omit to disable billing UI)
VITE_REVENUECAT_PUBLIC_API_KEY=

# PostHog — required by DesktopConfigValuesSchema (main process) and WebClientConfigSchema (renderer)
# Schema hard-fails at boot if missing or empty. Set to a real phc_* key.
POSTHOG_API_KEY="phc_xxxxxxxxxxxx"
VITE_POSTHOG_KEY="phc_xxxxxxxxxxxx"
VITE_POSTHOG_HOST=https://us.i.posthog.com
