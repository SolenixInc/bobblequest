{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../..",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client", "@testing-library/jest-dom"],
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@t/*": ["../../packages/*/src", "../../packages/*"]
    }
  },
  "include": ["src/main/**/*", "src/preload/**/*", "src/renderer/**/*", "src/types/**/*"]
}
