{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["bun-types"],
    "skipLibCheck": true
  },
  "include": ["**/*.ts"],
  "exclude": ["**/__tests__/**"]
}
