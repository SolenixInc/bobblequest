# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=template
DATABASE_URL=postgres://postgres:postgres@db:5432/template

# API
PORT=3000
NODE_ENV=development

# Clerk (auth) — consumer project wires own keys.
# Placeholders below satisfy schema validation so apps boot on a fresh `bun run up`.
# Replace with real keys from https://dashboard.clerk.com before enabling auth features.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_placeholder_replace_me
CLERK_SECRET_KEY=sk_test_placeholder_replace_me
# CLERK_ISSUER_URL=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# tRPC — points to the API container on the Docker network.
NEXT_PUBLIC_TRPC_URL=http://api:3000/trpc

# Billing (RevenueCat) — consumer project wires own keys
# REVENUECAT_API_KEY=
# REVENUECAT_WEBHOOK_SECRET=

# Analytics (PostHog) — consumer project wires own keys.
# Leave empty to run with no-op tracker; replace with real phc_* key to enable.
NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
# POSTHOG_PERSONAL_API_KEY=

# Runtime environment
NEXT_PUBLIC_ENVIRONMENT=development

# Website (apps/website)
# SITE_URL is the canonical public URL for the marketing site (used by OG metadata, sitemap).
# RUNTIME-ONLY — evaluated at first request, not at next build (server-only var, no NEXT_PUBLIC_ prefix).
# The Docker image is environment-portable: same image runs in dev/staging/prod with different values here.
# Omitting this var causes a clear runtime error on first request; the build will still succeed.
SITE_URL=http://localhost:3002

# Web (apps/web) — BUILD-TIME ARGs inlined by Next.js compiler
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY and NEXT_PUBLIC_TRPC_URL are required at build time
# (WebClientConfigSchema enforces min(1) and .url() respectively).
# Leave placeholders for local/CI builds; supply real values for production image builds.
# These are also passed as docker-compose build.args so docker compose build picks them up.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_placeholder_replace_me
NEXT_PUBLIC_TRPC_URL=http://api:3000/trpc
# NEXT_PUBLIC_REVENUECAT_PUBLIC_API_KEY=   # optional — absent/empty → NoOp billing tracker

# Cache (Redis)
REDIS_PASSWORD=redispassword
REDIS_URL=redis://:redispassword@redis:6379

# Mail (Mailpit dev catcher)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=noreply@example.com
# Mailpit Web UI: http://localhost:8025

# Object storage (MinIO)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=template-uploads
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# MinIO Console: http://localhost:9001
