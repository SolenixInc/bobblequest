.env
.env.*
**/.env
**/.env.*

# Test / coverage artefacts
coverage/
playwright-report/
test-results/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Turbo cache
.turbo/

# Agent / graph outputs (large, not needed at runtime)
graphify-out/
.claude/

# Git history
.git/
